{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "filament:dev": "npx tailwindcss --config resources/css/filament/doctor/tailwind.config.js --input resources/css/filament/doctor/theme.css --output public/css/filament/doctor/theme.css --watch",
        "filament:build": "tailwindcss --config resources/css/filament/doctor/tailwind.config.js --input resources/css/filament/doctor/theme.css --output public/css/filament/doctor/theme.css --minify",
        "dev:all": "concurrently \"npm run dev\" \"npm run filament:dev\""
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "autoprefixer": "^10.5.0",
        "axios": "^1.11.0",
        "concurrently": "^9.2.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.5.10",
        "tailwindcss": "^3.4.19",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "tom-select": "^2.5.2"
    }
}
